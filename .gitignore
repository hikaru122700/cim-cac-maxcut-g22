# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# wandb run data (may contain API keys / metadata)
wandb/

# Paper text dumps (copyrighted)
_cac_paper.txt

# Private problem statement
問題文.md

# Optuna study database (regenerable from tune_cim_optuna.py)
# *.db-journal / *.db-wal / *.db-shm は SQLite が一時的に作るファイル。
# auto_push.sh の git add -A と競合するので一緒に無視する。
results/**/*.db
results/**/*.db-journal
results/**/*.db-wal
results/**/*.db-shm

# Portable external tools (MinGW gcc, rudy, etc. — regenerable via tools/install.md)
tools/

# Local temp / backup files
*.tmp
input/K2000_numpy_seed0_backup.txt
